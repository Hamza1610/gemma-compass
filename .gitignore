# Gemma Compass gitignore

# OS specific files
.DS_Store
Thumbs.db
db.sqlite3

# Python virtual environment & caches
backend/venv/
backend/.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Databases & local uploads
backend/*.db
backend/*.db-journal
backend/uploads/*
!backend/uploads/.gitkeep

# Node & Next.js builds
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.env.local
frontend/.env.production.local
frontend/.env.development.local

# Project specific exclusions
gemma-compass-architecture.md

*.env