# Gemma Compass - Backend Configuration Example
# Copy this file to .env and modify values as needed

# URL to local Ollama API
# Default: http://localhost:11434/v1 (OpenAI-compatible)
OLLAMA_URL=http://localhost:11434/v1

# Target Gemma model tag for chat/explainer
# Use gemma4:e2b for weaker laptops (~2GB RAM), gemma4:e4b for standard setups
MODEL_TAG=gemma4:e2b

# Embedding model for RAG indexing
EMBEDDING_MODEL_TAG=nomic-embed-text

# Database Connection URL (SQLite)
DATABASE_URL=sqlite:///gemma_compass.db
